"년)"
)
)
pyramid_data <- pyramid_data %>%
left_join(total_pop_by_year, by = "year") %>%
mutate(
frame_label = factor(frame_label, levels = total_pop_by_year$frame_label)
)
p <- ggplot(pyramid_data, aes(x = age, y = plot_pop, fill = sex)) +
geom_col(width = 0.9) +
coord_flip() +
scale_y_continuous(
labels = function(x) format(abs(x), big.mark = ",")
) +
scale_fill_manual(
name = "성별",
values = c(
"남" = "#00AFC4",
"여" = "#006D6F"
)
) +
labs(
title = "대한민국 인구피라미드 변화",
subtitle = "총인구: {current_frame}",
x = NULL,
y = "인구수(천명)"
) +
theme_bw(base_size = 12) +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
plot.subtitle = element_text(hjust = 0.5, face = "bold"),
legend.title = element_text(face = "bold"),
legend.position = "right"
) +
transition_manual(frame_label)
animate(
p,
nframes = 180,
fps = 20,
width = 900,
height = 650,
end_pause = 40,
renderer = gifski_renderer("korea_population_pyramid_2025_2100.gif")
)
animate(
p,
nframes = 180,
fps = 20,
width = 900,
height = 650,
end_pause = 40,
renderer = gifski_renderer(
"figures/korea_population_pyramid_2025_2100.gif"
)
)
getwd()
animate(
p,
nframes = 180,
fps = 20,
width = 900,
height = 650,
end_pause = 40,
renderer = gifski_renderer(
"figure/korea_population_pyramid_2025_2100.gif"
)
)
