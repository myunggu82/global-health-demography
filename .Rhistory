# 3. wide data를 long data로 변환
d0 <- raw %>%
rename(
orig_reg = 전출지별,
dest_reg = 전입지별
) %>%
pivot_longer(
cols = contains("이동자수"),
names_to = "year_item",
values_to = "flow"
) %>%
mutate(
year0 = str_extract(year_item, "\\d{4}") %>% as.numeric(),
flow = as.numeric(str_replace_all(as.character(flow), ",", ""))
) %>%
filter(
orig_reg != "전국",
dest_reg != "전국",
orig_reg != dest_reg,
!is.na(year0),
!is.na(flow)
) %>%
select(year0, orig_reg, dest_reg, flow)
# 3. wide data를 long data로 변환
d0 <- raw %>%
rename(
orig_reg = 전출지별,
dest_reg = 전입지별
) %>%
mutate(
across(contains("이동자수"), as.character)
) %>%
pivot_longer(
cols = contains("이동자수"),
names_to = "year_item",
values_to = "flow"
) %>%
mutate(
year0 = str_extract(year_item, "\\d{4}") %>% as.numeric(),
flow = str_replace_all(flow, ",", ""),
flow = na_if(flow, "-"),
flow = as.numeric(flow)
) %>%
filter(
orig_reg != "전국",
dest_reg != "전국",
orig_reg != dest_reg,
!is.na(year0),
!is.na(flow)
) %>%
select(year0, orig_reg, dest_reg, flow)
d0
d0
# 2. 데이터 불러오기
raw <- read_excel(
"~/Desktop/global-health-demography/data/korea.xlsx",
sheet = "데이터",
skip = 0
)
# 3. wide data를 long data로 변환
d0 <- raw %>%
slice(-1) %>%   # 두 번째 줄: 이동자수(명) 제거
rename(
dest_reg = 전입지별,
orig_reg = 전출지별
) %>%
pivot_longer(
cols = matches("^20"),
names_to = "year0",
values_to = "flow"
) %>%
mutate(
year0 = as.numeric(year0),
flow = as.numeric(flow)
) %>%
filter(
orig_reg != "전국",
dest_reg != "전국",
orig_reg != dest_reg,
!is.na(flow)
) %>%
select(year0, orig_reg, dest_reg, flow)
d0
write_csv(d0,"~/Desktop/global-health-demography/data/korea_mig.xlsx")
d2 <- d0 %>%
mutate(
corridor = paste(orig_reg, dest_reg, sep = " -> "),
ease = "linear"
) %>%
select(corridor, year0, flow, ease) %>%
tween_elements(
time = "year0",
group = "corridor",
ease = "ease",
nframes = 100
) %>%
as_tibble()
# corridor 다시 분리
d2 <- d2 %>%
separate(
col = .group,
into = c("orig_reg", "dest_reg"),
sep = " -> "
) %>%
select(orig_reg, dest_reg, flow, everything()) %>%
mutate(flow = flow / 10000)   # 만 명 단위
d2
region_col <- setNames(
hue_pal()(length(regions)),
regions
)
library(scales)
regions <- sort(unique(c(d0$orig_reg, d0$dest_reg)))
region_col <- setNames(
hue_pal()(length(regions)),
regions
)
reg_max <- d0 %>%
mutate(flow = flow / 10000) %>%
group_by(year0, orig_reg) %>%
summarise(out = sum(flow), .groups = "drop") %>%
rename(region = orig_reg) %>%
full_join(
d0 %>%
mutate(flow = flow / 10000) %>%
group_by(year0, dest_reg) %>%
summarise(inflow = sum(flow), .groups = "drop") %>%
rename(region = dest_reg),
by = c("year0", "region")
) %>%
mutate(
out = replace_na(out, 0),
inflow = replace_na(inflow, 0),
total = out + inflow
) %>%
group_by(region) %>%
summarise(max_total = max(total), .groups = "drop") %>%
deframe()
dir.create("./figure", showWarnings = FALSE)
for(f in sort(unique(d2$.frame))){
png(
file = paste0("./figure/korea_chord_", sprintf("%03d", f), ".png"),
width = 1000,
height = 1000
)
circos.clear()
par(mar = rep(0, 4))
circos.par(
start.degree = 90,
gap.degree = 3,
track.margin = c(-0.1, 0.1),
points.overflow.warning = FALSE
)
chord_data <- d2 %>%
filter(.frame == f) %>%
select(orig_reg, dest_reg, flow)
year_label <- round(mean(d2$year0[d2$.frame == f]))
chordDiagram(
x = chord_data,
directional = 1,
order = regions,
grid.col = region_col,
transparency = 0.25,
annotationTrack = "grid",
xmax = reg_max
)
circos.track(
track.index = 1,
bg.border = NA,
panel.fun = function(x, y){
xlim <- get.cell.meta.data("xlim")
sector.index <- get.cell.meta.data("sector.index")
circos.text(
x = mean(xlim),
y = 3,
labels = sector.index,
facing = "bending",
cex = 0.8
)
}
)
text(
x = 0,
y = 0,
labels = year_label,
cex = 3,
font = 2
)
dev.off()
}
library(magick)
files <- paste0(
"./figure/korea_chord_",
sprintf("%03d", 0:99),
".png"
)
img <- image_read(files)
img <- image_scale(img, "600x600")
animation <- image_animate(
img,
fps = 10,
optimize = TRUE
)
print(animation)
